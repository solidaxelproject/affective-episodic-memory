+
+            // {"layers": {"25": [n_embd floats], "31": [...]}} -> arbitrary per-layer vectors, or
+            // {"vector": [n_embd floats], "il_start": a, "il_end": b} -> same vector on a range
+            // layer indices are llama.cpp 0-based block indices; layer 0 is not injectable
+            std::map<int32_t, std::vector<float>> rows;
+            if (body.contains("layers")) {
+                for (const auto & el : body.at("layers").items()) {
+                    rows[std::stoi(el.key())] = el.value().get<std::vector<float>>();
+                }
+            } else if (body.contains("vector")) {
+                const auto vec = body.at("vector").get<std::vector<float>>();
+                const int32_t a = json_value(body, "il_start", 1);
+                const int32_t b = json_value(body, "il_end", n_layer - 1);
+                for (int32_t il = a; il <= b; il++) {
+                    rows[il] = vec;
+                }
+            }
+
+            if (rows.empty()) {
+                res->error(format_error_response("provide `layers`, `vector` or `clear: true`", ERROR_TYPE_INVALID_REQUEST));
+                return res;
+            }
+            for (const auto & [il, v] : rows) {
+                if (il < 1 || il >= n_layer) {
+                    res->error(format_error_response(string_format(
+                        "layer %d out of range [1, %d)", il, n_layer), ERROR_TYPE_INVALID_REQUEST));
+                    return res;
+                }
+                if ((int32_t) v.size() != n_embd) {
+                    res->error(format_error_response(string_format(
+                        "layer %d vector has wrong size (%zu, expected %d)", il, v.size(), n_embd), ERROR_TYPE_INVALID_REQUEST));
+                    return res;
+                }
+            }
+
+            task.cvec_il_start = rows.begin()->first;
+            task.cvec_il_end   = rows.rbegin()->first;
