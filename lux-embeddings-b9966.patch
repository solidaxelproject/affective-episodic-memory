+//
+// helpers used by routes
+//
+
+// public llama.h does not expose model.tok_embd, so re-parse the GGUF file to read selected rows
+static std::vector<std::vector<float>> extract_token_embeddings(
+        const std::string & model_path,
+        const llama_model * model,
+        const llama_vocab * vocab,
+        const std::vector<llama_token> & tokens) {
+    if (model_path.empty()) {
+        throw std::runtime_error("model file path is unavailable");
+    }
+
+    const int32_t n_embd_inp = llama_model_n_embd(model);
+    const int32_t n_vocab    = llama_vocab_n_tokens(vocab);
+
+    gguf_init_params gp { /*no_alloc =*/ true, /*ctx =*/ nullptr };
+    gguf_context * gctx = gguf_init_from_file(model_path.c_str(), gp);
+    if (!gctx) {
+        throw std::runtime_error("failed to open GGUF file: " + model_path);
+    }
+
+    int64_t tid = gguf_find_tensor(gctx, "token_embd.weight");
+    if (tid < 0) {
+        tid = gguf_find_tensor(gctx, "tok_embeddings.weight");
+    }
+    if (tid < 0) {
+        gguf_free(gctx);
+        throw std::runtime_error("token embedding tensor not found in GGUF file");
+    }
+
+    const ggml_type type     = gguf_get_tensor_type(gctx, tid);
+    const size_t base_off    = gguf_get_data_offset(gctx) + gguf_get_tensor_offset(gctx, tid);
+    const size_t row_size    = ggml_row_size(type, n_embd_inp);
+    const size_t expect_size = row_size * (size_t) n_vocab;
+    const size_t actual_size = gguf_get_tensor_size(gctx, tid);
+
+    if (actual_size != expect_size) {
+        gguf_free(gctx);
+        throw std::runtime_error(string_format(
+            "token embedding tensor size mismatch (got %zu, expected %zu = %d rows * %zu bytes)",
+            actual_size, expect_size, n_vocab, row_size));
+    }
+
+    const ggml_type_traits * traits = ggml_get_type_traits(type);
+    if (type != GGML_TYPE_F32 && (!traits || !traits->to_float)) {
+        gguf_free(gctx);
+        throw std::runtime_error(string_format("no dequantizer for tensor type %d", (int) type));
+    }
+
+    FILE * f = fopen(model_path.c_str(), "rb");
+    if (!f) {
+        gguf_free(gctx);
+        throw std::runtime_error("failed to open model file for reading: " + model_path);
+    }
+
+    std::vector<uint8_t> rowbuf(row_size);
+    std::vector<std::vector<float>> result;
+    result.reserve(tokens.size());
+
+    for (llama_token tok : tokens) {
+        if (tok < 0 || tok >= n_vocab) {
+            fclose(f);
+            gguf_free(gctx);
+            throw std::runtime_error(string_format("token id %d out of range [0, %d)", (int) tok, n_vocab));
+        }
+        const size_t off = base_off + (size_t) tok * row_size;
+#ifdef _WIN32
+        if (_fseeki64(f, (int64_t) off, SEEK_SET) != 0) {
+#else
+        if (fseeko(f, (off_t) off, SEEK_SET) != 0) {
+#endif
+            fclose(f);
+            gguf_free(gctx);
+            throw std::runtime_error("fseek failed on model file");
+        }
+        if (fread(rowbuf.data(), 1, row_size, f) != row_size) {
+            fclose(f);
+            gguf_free(gctx);
+            throw std::runtime_error("short read on model file");
+        }
+        std::vector<float> row(n_embd_inp);
+        if (type == GGML_TYPE_F32) {
+            std::memcpy(row.data(), rowbuf.data(), (size_t) n_embd_inp * sizeof(float));
+        } else {
+            traits->to_float(rowbuf.data(), row.data(), n_embd_inp);
+        }
+        result.push_back(std::move(row));
+    }
+
+    fclose(f);
+    gguf_free(gctx);
+    return result;
+}
+
+// dequantize the full token_embd matrix once per process and keep it in memory (row-major: n_vocab * n_embd)
+static const std::vector<float> & load_full_input_embedding_matrix(
+        const std::string & model_path,
+        const llama_model * model,
+        const llama_vocab * vocab,
+        int32_t & out_n_vocab,
+        int32_t & out_n_embd) {
+    static std::mutex         mtx;
+    static std::string        cached_path;
+    static std::vector<float> cached;
+    static int32_t            cached_n_vocab = 0;
+    static int32_t            cached_n_embd  = 0;
+
+    std::lock_guard<std::mutex> lock(mtx);
+
+    if (cached_path == model_path && !cached.empty()) {
+        out_n_vocab = cached_n_vocab;
+        out_n_embd  = cached_n_embd;
+        return cached;
+    }
+
+    if (model_path.empty()) {
+        throw std::runtime_error("model file path is unavailable");
+    }
+
+    const int32_t n_embd_inp = llama_model_n_embd(model);
+    const int32_t n_vocab    = llama_vocab_n_tokens(vocab);
+
+    gguf_init_params gp { /*no_alloc =*/ true, /*ctx =*/ nullptr };
+    gguf_context * gctx = gguf_init_from_file(model_path.c_str(), gp);
+    if (!gctx) {
+        throw std::runtime_error("failed to open GGUF file: " + model_path);
+    }
+
+    int64_t tid = gguf_find_tensor(gctx, "token_embd.weight");
+    if (tid < 0) {
+        tid = gguf_find_tensor(gctx, "tok_embeddings.weight");
+    }
+    if (tid < 0) {
+        gguf_free(gctx);
+        throw std::runtime_error("token embedding tensor not found in GGUF file");
+    }
+
+    const ggml_type type     = gguf_get_tensor_type(gctx, tid);
+    const size_t base_off    = gguf_get_data_offset(gctx) + gguf_get_tensor_offset(gctx, tid);
+    const size_t row_size    = ggml_row_size(type, n_embd_inp);
+    const size_t expect_size = row_size * (size_t) n_vocab;
+    const size_t actual_size = gguf_get_tensor_size(gctx, tid);
+
+    if (actual_size != expect_size) {
+        gguf_free(gctx);
+        throw std::runtime_error(string_format(
+            "token embedding tensor size mismatch (got %zu, expected %zu = %d rows * %zu bytes)",
+            actual_size, expect_size, n_vocab, row_size));
+    }
+
+    const ggml_type_traits * traits = ggml_get_type_traits(type);
+    if (type != GGML_TYPE_F32 && (!traits || !traits->to_float)) {
+        gguf_free(gctx);
+        throw std::runtime_error(string_format("no dequantizer for tensor type %d", (int) type));
+    }
+
+    FILE * f = fopen(model_path.c_str(), "rb");
+    if (!f) {
+        gguf_free(gctx);
+        throw std::runtime_error("failed to open model file for reading: " + model_path);
+    }
+
+#ifdef _WIN32
+    if (_fseeki64(f, (int64_t) base_off, SEEK_SET) != 0) {
+#else
+    if (fseeko(f, (off_t) base_off, SEEK_SET) != 0) {
+#endif
+        fclose(f);
+        gguf_free(gctx);
+        throw std::runtime_error("fseek failed on model file");
+    }
+
+    std::vector<uint8_t> raw(expect_size);
+    if (fread(raw.data(), 1, expect_size, f) != expect_size) {
+        fclose(f);
+        gguf_free(gctx);
+        throw std::runtime_error("short read on model file");
+    }
+    fclose(f);
+    gguf_free(gctx);
+
+    std::vector<float> matrix((size_t) n_vocab * (size_t) n_embd_inp);
+    if (type == GGML_TYPE_F32) {
+        std::memcpy(matrix.data(), raw.data(), expect_size);
+    } else {
+        for (int32_t r = 0; r < n_vocab; ++r) {
+            traits->to_float(raw.data()     + (size_t) r * row_size,
+                             matrix.data()  + (size_t) r * n_embd_inp,
+                             n_embd_inp);
+        }
+    }
+
+    cached         = std::move(matrix);
+    cached_path    = model_path;
+    cached_n_vocab = n_vocab;
+    cached_n_embd  = n_embd_inp;
+
+    out_n_vocab = cached_n_vocab;
+    out_n_embd  = cached_n_embd;
+    return cached;
+}
